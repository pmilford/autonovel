# =========================================================================
# autonovel environment (.env)
# =========================================================================
# The rewrite's runtime commands (/autonovel:*) run inside your Claude Code
# subscription, so they do NOT need ANTHROPIC_API_KEY. The legacy Python
# scripts (evaluate.py, review.py, …) that still live in PIPELINE.md
# instructions do — they call api.anthropic.com directly. Those scripts
# are scheduled for deletion in PR 9; until then keep the key if you
# want to run them.

# --- Anthropic (legacy Python scripts only; PR 9 cleanup target) ---------
ANTHROPIC_API_KEY=sk-ant-...
AUTONOVEL_WRITER_MODEL=claude-sonnet-4-6
AUTONOVEL_JUDGE_MODEL=claude-opus-4-7
AUTONOVEL_REVIEW_MODEL=claude-opus-4-7
AUTONOVEL_API_BASE_URL=https://api.anthropic.com

# --- PR 7 export API keys (optional — only needed for the matching cmd) --

# fal.ai (default image provider). Needed by /autonovel:art-curate and
# /autonovel:art-ornaments-all. Swap providers via project.yaml :: image.provider.
FAL_KEY=your-fal-api-key-here

# ElevenLabs — needed by /autonovel:audiobook-voices --list,
# /autonovel:audiobook-generate. Leave unset if you don't build audiobooks.
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# --- Smoke-test auth override --------------------------------------------
# By default smoke tests strip ANTHROPIC_API_KEY so `claude -p` uses your
# subscription auth (free against Claude Max / Team / Pro). Set this to 1
# to preserve the key (pay-per-token) — useful for reproducing billing or
# rate-limit issues.
# AUTONOVEL_SMOKE_USE_API_KEY=1

# =========================================================================
# External CLI tools autonovel shells out to (install via your OS package
# manager; `autonovel doctor` enumerates any that are missing):
#
#   tectonic      — PDF typesetting (/autonovel:typeset)
#   pandoc        — ePub generation (/autonovel:typeset)
#   potrace       — PNG → SVG (/autonovel:art-vectorize)
#   ffmpeg        — m4b audiobook (/autonovel:audiobook-assemble --format m4b)
#   rsvg-convert  — SVG → PDF for print-quality ornaments
#                  (/autonovel:typeset --convert-vectors)
#   fontconfig    — EB Garamond + Bebas Neue lookup for cover renderers
#
# Linux:   apt install tectonic pandoc potrace ffmpeg librsvg2-bin fontconfig
# macOS:   brew install tectonic pandoc potrace ffmpeg librsvg fontconfig
#
# Python extras for the export path: `pip install autonovel[export]`
# (Pillow for cover renderers, pydub for audiobook assembly).
# =========================================================================
