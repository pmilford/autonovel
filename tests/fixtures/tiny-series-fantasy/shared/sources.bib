% Real-world citations for historical or research-grounded series.
% BibTeX entries keyed by shortname; referenced from shared/research/notes/
% and consumed by /autonovel:research and /autonovel:add-source.
%
% Format: every entry has a shortname (what research notes cite with
% `[shortname]`). The minimum viable entry is `@misc` with `title`, `url`,
% and `urldate`. For academic work, prefer `@book` / `@article` and
% include `author`, `publisher` / `journal`, and `year`.
%
% Example (uncomment and edit):
%
% @misc{britannica-venice,
%   title     = {Venice, History},
%   author    = {{Encyclop{\ae}dia Britannica}},
%   url       = {https://www.britannica.com/place/Venice/History},
%   urldate   = {2026-04-24},
%   note      = {Primary source for the series; see shared/research/sources.yaml},
% }
%
% @book{palmer-apothecary-1985,
%   title     = {The Apothecary in Renaissance Europe},
%   author    = {Palmer, Richard},
%   publisher = {Example University Press},
%   year      = {1985},
% }
